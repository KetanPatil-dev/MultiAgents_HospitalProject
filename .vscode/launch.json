{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "MAS ZeroWardRush",
			"type": "debugpy",
			"request": "attach",
			"internalConsoleOptions": "openOnFirstSessionStart",
			"connect": {
				"host": "localhost",
				"port": 1234
			},
			"pathMappings": [
				{
					"localRoot": "${workspaceFolder}",
